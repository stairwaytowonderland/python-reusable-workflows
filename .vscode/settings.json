{
	/*
		Editor settings
	*/
	"editor.formatOnSave": true,
	"editor.formatOnType": false,
	"editor.formatOnPaste": false,
	// https://marketplace.visualstudio.com/items?itemName=esbenp.prettier-vscode
	"editor.defaultFormatter": "esbenp.prettier-vscode",
	"editor.detectIndentation": false,
	"editor.tabSize": 4,
	"editor.renderWhitespace": "boundary",
	"editor.codeActionsOnSave": {
		"source.fixAll": "explicit"
	},

	/*
		Prettier settings
	*/
	"prettier.useEditorConfig": true,
	"prettier.configPath": ".prettierrc",

	/*
		Files settings
	*/
	"files.eol": "\n",
	"files.encoding": "utf8",
	"files.trimTrailingWhitespace": true,
	"files.insertFinalNewline": true,
	"files.associations": {
		"*.Brewfile": "ruby",
		"*.cron": "shellscript",
		"*.lib": "shellscript",
		"*yaml.tftpl": "jinja-yaml",
		"*json.tftpl": "jinja-json",
		"LICENSE": "plaintext"
	},
	"files.exclude": {
		"**/.git": true,
		"**/.DS_Store": true,
		"**/dist": true,
		"**/build": true,
		"**/__pycache__": true,
		"**/.venv": true
	},

	/*
		Git settings
	*/
	"git.autofetch": true,
	"git.enableSmartCommit": true,
	"git.confirmSync": false,

	/*
		Dockerfile settings
	*/
	"[dockerfile]": {
		"editor.defaultFormatter": "ms-azuretools.vscode-containers",
		"editor.formatOnSave": false
	},

	/*
		YAML settings
	*/
	"[yaml]": {
		"editor.defaultFormatter": "redhat.vscode-yaml",
		"editor.formatOnSave": true
	},

	/*
		Markdown settings
	*/
	"[markdown]": {
		"editor.defaultFormatter": "yzhang.markdown-all-in-one",
		"editor.formatOnSave": true,
		"editor.formatOnPaste": true,
		"editor.codeActionsOnSave": {
			"source.fixAll.markdownlint": "explicit"
		}
	},
	// https://github.com/yzhang-gh/vscode-markdown?tab=readme-ov-file#supported-settings
	"markdown.extension.orderedList.marker": "one",
	"markdown.extension.toc.unorderedList.marker": "-",

	/*
		Configuration Language settings
	*/
	"[toml]": {
		"editor.defaultFormatter": "tamasfe.even-better-toml",
		"editor.formatOnSave": true
	},

	/*
		Python settings
		# If formatting isn't working after changing black-formatter.args ...
		# In the Command Pallete search for 'Black Formatter: Restart Server'

		# Sample pyproject.toml
		[tool.black]
		line-length = 88
		target-version = ['py310', 'py311', 'py312']
		include = '\.pyi?$'
	*/
	"black-formatter.args": ["--config", "${workspaceFolder}/pyproject.toml"],
	"isort.args": ["--profile", "black"],
	"[python]": {
		"editor.defaultFormatter": "ms-python.black-formatter",
		"editor.formatOnSave": true,
		"editor.codeActionsOnSave": {
			"source.organizeImports": "explicit"
		}
	}
}
